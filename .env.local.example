# Copy this file to `.env.local` and fill in your Firebase web config.
# Firebase console → Project settings → General → Your apps → SDK setup and configuration.
# These NEXT_PUBLIC_* values ship in the client; Firestore is protected by security rules.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Shared family workspace id (all family devices share this space). Optional.
NEXT_PUBLIC_FAMILY_WORKSPACE_ID=family

# GitHub Pages project path, e.g. "/StudyFlow". Leave empty for local dev
# or when using a custom domain / <user>.github.io root repo.
# NEXT_PUBLIC_BASE_PATH=

rules_version = '2';

// StudyFlow security rules.
//
// The app signs every device in with Firebase Anonymous Auth (invisible to the
// user — no login screen). All family data lives under a single shared
// workspace document. These rules require a valid Firebase auth token, so
// requests that don't come through the app are rejected.
//
// Hardening tip: enable Firebase App Check (reCAPTCHA) to further restrict
// access to your own app. See README "보안 강화(선택)".

service cloud.firestore {
  match /databases/{database}/documents {

    // Shared family workspace and everything under it.
    match /workspaces/{workspaceId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
